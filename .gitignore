# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.js
package-lock.json

# Environment / secrets
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Next.js
.next/
out/
build/
dist/

